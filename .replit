modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_object_storage:2.0.0", "python_openai_ai_integrations:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cairo", "ffmpeg-full", "freetype", "ghostscript", "gobject-introspection", "gtk3", "pkg-config", "qhull", "tcl", "tk"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Run"
mode = "sequential"
author = 47286943

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python shared_libs/ai_helpers.py"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Form Network"

[[workflows.workflow]]
name = "Form Network"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"
waitForPort = 5000

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python pro_processor.py"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Pro Processor"
mode = "sequential"
author = 52806342

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python pro_processor.py"

[[ports]]
localPort = 5000
externalPort = 80
